# Secrets for the intraday_tv_schwab_bot. Copy this file to `.env` at the
# repo root and fill in real values. `.env` is gitignored and must never be
# committed.
#
# Precedence: yaml value (if real) > environment variable > .env file.
# Placeholders like YOUR_APP_KEY are treated as "not set".

# --- Schwab developer app credentials (REQUIRED) ---------------------------
# Obtained from https://developer.schwab.com/ (your registered app).
SCHWAB_APP_KEY=YOUR_APP_KEY
SCHWAB_APP_SECRET=YOUR_APP_SECRET

# --- Schwab account hash (optional) -----------------------------------------
# Leave blank to auto-resolve the linked account. Set this if your login has
# multiple accounts and you need to pin trading to a specific one.
SCHWAB_ACCOUNT_HASH=

# --- Schwab token-DB encryption key (optional, strongly recommended) --------
# Fernet key used by schwabdev to encrypt the OAuth tokens stored in
# .schwabdev/tokens.db. Leave blank to leave the DB unencrypted. Generate a
# fresh key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Save the output verbatim below (a 44-char base64 string ending in '=').
SCHWAB_ENCRYPTION_KEY=

# --- TradingView session cookie (optional) ---------------------------------
# Leave blank if you don't have a paid/logged-in session. Screener results
# may be delayed ~15 minutes without it. To grab the cookie: log into
# tradingview.com, open devtools -> Application -> Cookies, copy `sessionid`.
TRADINGVIEW_SESSIONID=
